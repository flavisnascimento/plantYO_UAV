<?xml version="1.0"?>
<sdf version="1.6">
  <model name="arbusto">
    <static>true</static>
    
    <link name="base">
      <!-- Tronco central fino -->
      <visual name="tronco">
        <pose>0 0 0.08 0 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.02</radius>
            <length>0.16</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.35 0.2 0.1 1</ambient>
          <diffuse>0.5 0.3 0.15 1</diffuse>
        </material>
      </visual>
      
      <!-- Copa principal (esfera achatada) -->
      <visual name="copa_principal">
