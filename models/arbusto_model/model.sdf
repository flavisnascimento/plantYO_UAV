        <geometry>
          <sphere>
            <radius>0.12</radius>
          </sphere>
        </geometry>
        <material>
          <ambient>0.1 0.5 0.05 1</ambient>
          <diffuse>0.2 0.65 0.1 1</diffuse>
          <specular>0.05 0.2 0.02 1</specular>
        </material>
      </visual>
      
      <!-- Copa lateral esquerda -->
      <visual name="copa_esq">
