Panels:
  - Class: rviz/Displays
    Help Height: 70
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /Global Options1
        - /Campo1
        - /Drone1
        - /Drone1/TF1
        - /Missao1
      Splitter Ratio: 0.5
    Tree Height: 264
  - Class: rviz/Views
    Expanded:
      - /Current View1
    Name: Views
    Splitter Ratio: 0.5
Preferences:
  PromptSaveOnExit: true
Toolbars:
  toolButtonStyle: 2
Visualization Manager:
  Class: ""
  Displays:
    - Class: rviz/Group
      Displays:
        - Alpha: 0.5
          Cell Size: 1
          Class: rviz/Grid
          Color: 60; 60; 60
          Enabled: true
          Line Style:
            Line Width: 0.019999999552965164
            Value: Lines
          Name: Grid 1m
          Normal Cell Count: 0
          Offset:
            X: 50
            Y: 50
            Z: 0
          Plane: XY
          Plane Cell Count: 100
          Reference Frame: <Fixed Frame>
          Value: true
        - Alpha: 0.5
          Cell Size: 10
          Class: rviz/Grid
          Color: 100; 100; 100
          Enabled: true
          Line Style:
            Line Width: 0.05000000074505806
            Value: Lines
          Name: Grid 10m
          Normal Cell Count: 0
          Offset:
            X: 50
            Y: 50
            Z: 0
          Plane: XY
          Plane Cell Count: 10
          Reference Frame: <Fixed Frame>
          Value: true
      Enabled: true
      Name: Campo
    - Class: rviz/Group
