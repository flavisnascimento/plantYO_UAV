          Name: TF
          Show Arrows: true
          Show Axes: true
          Show Names: true
          Tree:
            base_link:
              base_link_frd:
                {}
            map:
              map_ned:
                {}
            odom:
              odom_ned:
                {}
            uav1/fcu:
              uav1/fcu/arms:
                {}
              uav1/fcu/arms_red:
                {}
              uav1/fcu/props:
                {}
              uav1/fcu/uav_marker:
                {}
